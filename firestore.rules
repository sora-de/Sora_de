rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ?
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role : null;
    }
    
    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }
    
    function isStaff() {
      return request.auth != null && getUserRole() == 'staff';
    }
    
    function isStaffOrAdmin() {
      return isAdmin() || isStaff();
    }

    match /app_config/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    match /inventory/{document=**} {
      allow read, write: if isStaffOrAdmin();
    }
    match /gift_orders/{document=**} {
      allow read, write: if isStaffOrAdmin();
    }
    match /order_presets/{document=**} {
      allow read, write: if isStaffOrAdmin();
    }
    match /stock_adjustments/{document=**} {
      allow read, write: if isStaffOrAdmin();
    }
    match /inventory_meta/{document=**} {
      allow read, write: if isStaffOrAdmin();
    }
    match /purchases/{document=**} {
      allow read, write: if isStaffOrAdmin();
    }
    match /daily_sales/{document=**} {
      allow read, write: if isStaffOrAdmin();
    }
    match /daily_collections/{document=**} {
      allow read, write: if isStaffOrAdmin();
    }

    match /revenues/{document=**} {
      allow read, write: if isAdmin();
    }
    match /expenses/{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
